# Postgres connection string. On Railway, Postgres plugin sets this automatically as DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# App password (used to log in). Pick something strong.
APP_PASSWORD="change-me"

# Random string used to sign the session cookie. 32+ chars recommended.
SESSION_SECRET="please-replace-with-a-long-random-string"

# USDA FoodData Central API key. Get one free at https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY="DEMO_KEY"
