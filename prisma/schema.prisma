// Prisma schema for the nutrition app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Weighing {
  id        String   @id @default(cuid())
  date      DateTime
  weightKg  Float
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}

model FoodLog {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  source      String?
  fdcId       Int?
  offCode     String?
  servingG    Float?
  servings    Float    @default(1)
  calories    Float
  proteinG    Float    @default(0)
  carbsG      Float    @default(0)
  fatG        Float    @default(0)
  mealType    String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model Favorite {
  id        String   @id @default(cuid())
  name      String
  source    String?
  fdcId     Int?
  offCode   String?
  servingG  Float?
  servings  Float    @default(1)
  calories  Float
  proteinG  Float    @default(0)
  carbsG    Float    @default(0)
  fatG      Float    @default(0)
  createdAt DateTime @default(now())
}

model Settings {
  id               Int       @id @default(1)
  dailyCalorieGoal Int       @default(2000)
  proteinGoalG     Int       @default(150)
  carbsGoalG       Int       @default(220)
  fatGoalG         Int       @default(70)
  heightCm         Float?
  startWeightKg    Float?
  goalWeightKg     Float?
  birthYear        Int?
  sex              String?
  activityLevel    String?
  targetDate       DateTime?
  weeklyRateKg     Float?
}
